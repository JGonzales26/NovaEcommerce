@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="mx-auto max-w-md rounded-lg border border-zinc-200 bg-white p-6 shadow-sm">
    <h1 class="text-2xl font-bold">Iniciar sesion</h1>
    <form method="post" class="mt-6 space-y-4">
        <div asp-validation-summary="ModelOnly"></div>
        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
        <div>
            <label asp-for="Email" class="text-sm font-medium"></label>
            <input asp-for="Email" class="field mt-1" autocomplete="email" />
            <span asp-validation-for="Email"></span>
        </div>
        <div>
            <label asp-for="Password" class="text-sm font-medium"></label>
            <input asp-for="Password" class="field mt-1" autocomplete="current-password" />
            <span asp-validation-for="Password"></span>
        </div>
        <label class="flex items-center gap-2 text-sm">
            <input asp-for="RememberMe" class="rounded border-zinc-300" />
            @Html.DisplayNameFor(m => m.RememberMe)
        </label>
        <button class="w-full rounded-md bg-emerald-600 px-4 py-3 font-semibold text-white hover:bg-emerald-700">Entrar</button>
    </form>
    <p class="mt-4 text-sm text-zinc-600">Admin demo: admin@ecommerce.local / Admin123!</p>
</div>
