@model IReadOnlyList<ProductDto>
@{
    ViewData["Title"] = "Inicio";
}

<section class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
    <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-emerald-700">Ecommerce moderno</p>
        <h1 class="mt-3 max-w-3xl text-4xl font-bold tracking-tight text-zinc-950 sm:text-5xl">NovaCommerce</h1>
        <p class="mt-2 text-sm text-zinc-600">Bienvenidos a nuestra tienda de tecnología. Explore nuestro catálogo con las últimas novedades.</p>
        <p class="mt-4 max-w-2xl text-lg leading-8 text-zinc-600">Catalogo, carrito, checkout, roles y panel administrativo sobre una arquitectura MVC mantenible.</p>
        <div class="mt-6 flex gap-3">
            <a asp-controller="Products" asp-action="Index" class="rounded-md bg-emerald-600 px-5 py-3 text-sm font-semibold text-white hover:bg-emerald-700">Ver catalogo</a>
            <a asp-controller="Account" asp-action="Register" class="rounded-md border border-zinc-300 px-5 py-3 text-sm font-semibold hover:bg-white">Crear cuenta</a>
        </div>
    </div>
    <img class="h-80 w-full rounded-lg object-cover shadow-sm" src="https://images.unsplash.com/photo-1556742502-ec7c0e9f34b1?auto=format&fit=crop&w=1200&q=80" alt="Compra online" />
</section>

<section class="mt-12">
    <div class="mb-5 flex items-end justify-between">
        <div>
            <h2 class="text-2xl font-bold">Productos destacados</h2>
            <p class="text-sm text-zinc-500">Seleccion curada con stock disponible.</p>
        </div>
        <a asp-controller="Products" asp-action="Index" class="text-sm font-semibold text-emerald-700">Todos</a>
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        @foreach (var product in Model)
        {
            <partial name="_ProductCard" model="product" />
        }
    </div>
</section>
