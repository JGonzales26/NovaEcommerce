@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="mx-auto max-w-3xl">
    <div class="mb-8">
        <h1 class="text-3xl font-bold tracking-tight text-zinc-900">Mi Cuenta</h1>
        <p class="mt-2 text-sm text-zinc-600">Actualiza y administra los detalles de tu perfil en NovaCommerce.</p>
    </div>

    <form asp-controller="Account" asp-action="UpdateProfile" method="post">
        
        <div class="overflow-hidden rounded-xl border border-zinc-200 bg-white shadow-sm">
            
            <div class="border-b border-zinc-200 bg-zinc-50/50 p-6">
                <div class="flex items-center gap-4">
                    <div class="flex h-12 w-12 items-center justify-center rounded-full bg-emerald-100 text-lg font-semibold text-emerald-700">
                        @ViewData["FullName"]?.ToString()?[0].ToString().ToUpper()
                    </div>
                    <div>
                        <h2 class="text-lg font-medium text-zinc-900">@ViewData["FullName"]</h2>
                        <p class="text-xs font-medium uppercase tracking-wider text-emerald-600">
                            Rol: @ViewData["Role"] @(ViewData["Role"]?.ToString() == "Admin" ? "• Administrador" : "")
                        </p>
                    </div>
                </div>
            </div>

            <div class="p-6 space-y-6">
                <div class="grid grid-cols-1 gap-x-4 gap-y-6 sm:grid-cols-2">

                    <div class="sm:col-span-2">
                        <label for="fullName" class="block text-sm font-medium text-zinc-700">Nombre Completo</label>
                        <input type="text" id="fullName" name="FullName" value="@ViewData["FullName"]" 
                               class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 bg-white text-zinc-900" required />
                    </div>

                    <div class="sm:col-span-2">
                        <label for="email" class="block text-sm font-medium text-zinc-700">Correo Electrónico</label>
                        <input type="email" id="email" name="Email" value="@ViewData["Email"]" 
                               class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 bg-white text-zinc-900" required />
                    </div>
                    
                   <div class="sm:col-span-1">
                        <label for="newPassword" class="block text-sm font-medium text-zinc-700">Nueva Contraseña</label>
                        <input type="password" id="newPassword" name="NewPassword" placeholder="Dejar en blanco para mantener actual"
                               class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 bg-white text-zinc-900" />
                   </div>

                   <div class="sm:col-span-1">
                        <label for="confirmPassword" class="block text-sm font-medium text-zinc-700">Confirmar Contraseña</label>
                        <input type="password" id="confirmPassword" name="ConfirmPassword" placeholder="Repite la nueva contraseña"
                               class="mt-1 block w-full rounded-md border border-zinc-300 px-3 py-2 text-sm focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500 bg-white text-zinc-900" />
                   </div>

                </div>
            </div>

            <div class="flex items-center justify-end gap-3 border-t border-zinc-200 bg-zinc-50/50 px-6 py-4">
                <a asp-controller="Home" asp-action="Index" class="rounded-md border border-zinc-300 bg-white px-4 py-2 text-sm font-medium text-zinc-700 hover:bg-zinc-50 transition-colors">
                    Cancelar
                </a>
                <button type="submit" class="rounded-md bg-emerald-600 px-4 py-2 text-sm font-medium text-white hover:bg-emerald-700 transition-colors shadow-sm">
                    Guardar Cambios
                </button>
            </div>

        </div>
    </form>
</div>