@model CartIndexViewModel
@{
    ViewData["Title"] = "Carrito";
}

<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-3xl font-bold">Carrito</h1>
        <p class="mt-1 text-zinc-600">Revisa los productos en tu carrito antes de continuar.</p>
    </div>
</div>

@if (Model.IsAuthenticated && Model.Cart.Items.Count > 0)
{
    <div class="grid gap-6 lg:grid-cols-[1fr_360px]">
        <div class="space-y-4">
            @foreach (var item in Model.Cart.Items)
            {
                <div class="flex gap-4 rounded-lg border border-zinc-200 bg-white p-4">
                    <img class="h-24 w-24 rounded-md object-cover" src="@item.ImageUrl" alt="@item.ProductName" />
                    <div class="flex flex-1 flex-col justify-between">
                        <div>
                            <h3 class="font-semibold">@item.ProductName</h3>
                            <p class="text-sm text-zinc-500">S/ @item.UnitPrice.ToString("0.00")</p>
                        </div>
                        <div class="flex items-center gap-4">
                            <form asp-action="Update" method="post" class="flex items-center gap-2">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <input type="number" name="quantity" value="@item.Quantity" min="1" max="100000"
                                       class="field w-20 text-center" />
                                <button class="rounded-md bg-zinc-100 px-3 py-1 text-sm hover:bg-zinc-200">Actualizar</button>
                            </form>
                            <form asp-action="Remove" method="post" class="ml-auto">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button class="text-sm text-red-600 hover:text-red-800">Eliminar</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="h-fit rounded-lg border border-zinc-200 bg-white p-6">
            <h2 class="mb-4 text-lg font-semibold">Resumen</h2>
            <div class="space-y-3 text-sm">
                <div class="flex justify-between">
                    <span class="text-zinc-500">Productos</span>
                    <span>@Model.Cart.TotalItems</span>
                </div>
                <div class="flex justify-between border-t border-zinc-200 pt-3 font-semibold">
                    <span>Total</span>
                    <span>S/ @Model.Cart.Total.ToString("0.00")</span>
                </div>
            </div>
            <a asp-controller="Products" asp-action="Index"
               class="mt-6 block rounded-md border border-zinc-300 px-4 py-2 text-center text-sm font-medium hover:bg-zinc-50">
                Seguir comprando
            </a>
        </div>
    </div>
}
else if (Model.IsAuthenticated)
{
    <div class="rounded-lg border border-zinc-200 bg-white p-12 text-center">
        <p class="text-lg text-zinc-500">Tu carrito esta vacio.</p>
        <a asp-controller="Products" asp-action="Index" class="mt-4 inline-block rounded-md bg-emerald-600 px-5 py-2 font-semibold text-white hover:bg-emerald-700">
            Explorar productos
        </a>
    </div>
}
else
{
    @* Anonimo: carrito renderizado via JS desde localStorage *@
    <div id="local-cart-container">
        <div id="local-cart-empty" class="rounded-lg border border-zinc-200 bg-white p-12 text-center">
            <p class="text-lg text-zinc-500">Tu carrito esta vacio.</p>
            <a asp-controller="Products" asp-action="Index" class="mt-4 inline-block rounded-md bg-emerald-600 px-5 py-2 font-semibold text-white hover:bg-emerald-700">
                Explorar productos
            </a>
        </div>
        <div id="local-cart-content" class="hidden grid gap-6 lg:grid-cols-[1fr_360px]">
            <div id="local-cart-items" class="space-y-4"></div>
            <div class="h-fit rounded-lg border border-zinc-200 bg-white p-6">
                <h2 class="mb-4 text-lg font-semibold">Resumen</h2>
                <div class="space-y-3 text-sm">
                    <div class="flex justify-between">
                        <span class="text-zinc-500">Productos</span>
                        <span id="local-cart-count">0</span>
                    </div>
                    <div class="flex justify-between border-t border-zinc-200 pt-3 font-semibold">
                        <span>Total</span>
                        <span id="local-cart-total">S/ 0.00</span>
                    </div>
                </div>
                <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="/Cart"
                   class="mt-4 block rounded-md bg-emerald-600 px-4 py-2 text-center text-sm font-semibold text-white hover:bg-emerald-700">
                    Inicia sesion para comprar
                </a>
                <a asp-controller="Products" asp-action="Index"
                   class="mt-3 block rounded-md border border-zinc-300 px-4 py-2 text-center text-sm font-medium hover:bg-zinc-50">
                    Seguir comprando
                </a>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
    (function() {
        if (@(Model.IsAuthenticated ? "true" : "false")) {
            @* Autenticado: sincronizar localStorage con BD *@
            const localItems = cartStorage.getCart();
            if (localItems.length > 0) {
                const syncItems = localItems.map(i => ({ productId: i.productId, quantity: i.quantity }));
                fetch('/Cart/Sync', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(syncItems)
                }).then(r => r.json()).then(data => {
                    if (data.success) {
                        cartStorage.clearCart();
                        location.reload();
                    }
                });
            }
            return;
        }

        @* Anonimo: renderizar desde localStorage *@
        function renderLocalCart() {
            const items = cartStorage.getCart();
            const emptyEl = document.getElementById('local-cart-empty');
            const contentEl = document.getElementById('local-cart-content');
            const itemsEl = document.getElementById('local-cart-items');
            const countEl = document.getElementById('local-cart-count');
            const totalEl = document.getElementById('local-cart-total');

            if (items.length === 0) {
                emptyEl.style.display = '';
                contentEl.classList.add('hidden');
                return;
            }

            emptyEl.style.display = 'none';
            contentEl.classList.remove('hidden');

            let total = 0;
            let count = 0;

            itemsEl.innerHTML = items.map(item => {
                const subtotal = item.unitPrice * item.quantity;
                total += subtotal;
                count += item.quantity;

                return `<div class="flex gap-4 rounded-lg border border-zinc-200 bg-white p-4">
                    <img class="h-24 w-24 rounded-md object-cover" src="${item.imageUrl}" alt="${item.productName}" />
                    <div class="flex flex-1 flex-col justify-between">
                        <div>
                            <h3 class="font-semibold">${item.productName}</h3>
                            <p class="text-sm text-zinc-500">S/ ${item.unitPrice.toFixed(2)}</p>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="flex items-center gap-2">
                                <input type="number" value="${item.quantity}" min="1" max="100000"
                                    class="field w-20 text-center"
                                    onchange="cartStorage.updateQuantity(${item.productId}, parseInt(this.value) || 1); renderLocalCart(); cartStorage.updateBadge();" />
                            </div>
                            <button onclick="cartStorage.removeItem(${item.productId}); renderLocalCart(); cartStorage.updateBadge();"
                                class="ml-auto text-sm text-red-600 hover:text-red-800">Eliminar</button>
                        </div>
                    </div>
                </div>`;
            }).join('');

            countEl.textContent = count;
            totalEl.textContent = 'S/ ' + total.toFixed(2);
        }

        renderLocalCart();
    })();
    </script>
}