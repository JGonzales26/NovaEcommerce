@model RegisterViewModel
@{
    ViewData["Title"] = "Registro";
}

<div class="mx-auto max-w-md rounded-lg border border-zinc-200 bg-white p-6 shadow-sm">
    <h1 class="text-2xl font-bold">Crear cuenta</h1>
    <form method="post" class="mt-6 space-y-4">
        <div asp-validation-summary="ModelOnly"></div>
        <div>
            <label asp-for="FullName" class="text-sm font-medium"></label>
            <input asp-for="FullName" class="field mt-1" />
            <span asp-validation-for="FullName"></span>
        </div>
        <div>
            <label asp-for="Email" class="text-sm font-medium"></label>
            <input asp-for="Email" class="field mt-1" />
            <span asp-validation-for="Email"></span>
        </div>
        <div>
            <label asp-for="Password" class="text-sm font-medium"></label>
            <input asp-for="Password" class="field mt-1" />
            <span asp-validation-for="Password"></span>
        </div>
        <div>
            <label asp-for="ConfirmPassword" class="text-sm font-medium"></label>
            <input asp-for="ConfirmPassword" class="field mt-1" />
            <span asp-validation-for="ConfirmPassword"></span>
        </div>
        <button class="w-full rounded-md bg-emerald-600 px-4 py-3 font-semibold text-white hover:bg-emerald-700">Registrarme</button>
    </form>
</div>
