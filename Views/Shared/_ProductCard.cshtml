@model ProductDto

<article class="overflow-hidden rounded-lg border border-zinc-200 bg-white shadow-sm">
    <a asp-controller="Products" asp-action="Details" asp-route-id="@Model.Id">
        <img class="h-48 w-full object-cover" src="@Model.ImageUrl" alt="@Model.Name" />
    </a>
    <div class="space-y-3 p-4">
        <div>
            <p class="text-xs font-medium uppercase text-emerald-700">@Model.CategoryName</p>
            <h3 class="mt-1 line-clamp-2 font-semibold">@Model.Name</h3>
        </div>
        <div class="flex items-center justify-between">
            <span class="font-bold">S/ @Model.Price.ToString("0.00")</span>
            <span class="text-xs text-zinc-500">@Model.Stock en stock</span>
        </div>
        <form asp-controller="Cart" asp-action="Add" method="post" class="flex gap-2">
            <input type="hidden" name="productId" value="@Model.Id" />
            <input type="hidden" name="quantity" value="1" />
            <button class="w-full rounded-md bg-zinc-900 px-3 py-2 text-sm font-semibold text-white hover:bg-zinc-700">Agregar</button>
        </form>
    </div>
</article>
