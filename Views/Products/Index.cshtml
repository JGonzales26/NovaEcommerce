@model ProductListViewModel
@{
    ViewData["Title"] = "Catalogo";
}

<div class="mb-6">
    <h1 class="text-3xl font-bold">Catalogo</h1>
    <p class="mt-1 text-zinc-600">Busca y filtra productos disponibles.</p>
</div>

<form method="get" class="mb-8 grid gap-3 rounded-lg border border-zinc-200 bg-white p-4 md:grid-cols-[1fr_220px_auto]">
    <input class="field" name="search" value="@Model.Search" placeholder="Buscar productos" />
    <select class="field" name="categoryId" asp-items="Model.Categories">
        <option value="">Todas las categorias</option>
    </select>
    <button class="rounded-md bg-emerald-600 px-5 py-2 font-semibold text-white hover:bg-emerald-700">Filtrar</button>
</form>

<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
    @foreach (var product in Model.Products.Items)
    {
        <partial name="_ProductCard" model="product" />
    }
</div>

<div class="mt-8 flex items-center justify-between text-sm">
    <span>Pagina @Model.Products.Page de @Math.Max(Model.Products.TotalPages, 1)</span>
    <div class="flex gap-2">
        @if (Model.Products.HasPrevious)
        {
            <a class="rounded-md border px-3 py-2" asp-route-page="@(Model.Products.Page - 1)" asp-route-search="@Model.Search" asp-route-categoryId="@Model.CategoryId">Anterior</a>
        }
        @if (Model.Products.HasNext)
        {
            <a class="rounded-md border px-3 py-2" asp-route-page="@(Model.Products.Page + 1)" asp-route-search="@Model.Search" asp-route-categoryId="@Model.CategoryId">Siguiente</a>
        }
    </div>
</div>
